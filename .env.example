# Application
NODE_ENV=development
APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

# PostgreSQL used when Next.js runs on the host machine
DATABASE_URL=postgresql://cowork:cowork_pass@localhost:5432/cowork_db

# Email
RESEND_API_KEY=
EMAIL_FROM=CoWork <noreply@example.com>

# Optional Google login, add only after credentials auth works
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=